{
  "name": "subradar-expo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:build:ios": "cross-env EAS_NO_VCS=1 EAS_BUILD_NO_EXPO_GO_WARNING=true eas build --platform ios --profile production",
    "eas:build:ios:nogit": "cross-env EAS_NO_VCS=1 EAS_BUILD_NO_EXPO_GO_WARNING=true eas build --platform ios --profile production",
    "eas:submit:ios": "cross-env EAS_NO_VCS=1 eas submit --platform ios --profile production --latest",
    "eas:update:production": "cross-env EAS_NO_VCS=1 eas update --channel production",
    "eas:update:preview": "cross-env EAS_NO_VCS=1 eas update --channel preview",
    "icon:recolor-bg": "node scripts/recolor-icon-background.mjs",
    "install-git": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-git-windows.ps1"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.7",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "i18n-js": "^4.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-iap": "^12.16.2",
    "react-native-pager-view": "6.9.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eas-cli": "^18.4.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
